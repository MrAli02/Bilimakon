# ============================================================
# BILIMMAKON — .env.local
# Bu faylni nusxalab .env.local nomiga o'zgartiring
# Vercel da Environment Variables bo'limiga kiriting
# ============================================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# ANTHROPIC (AI Mentor uchun)
ANTHROPIC_API_KEY=sk-ant-...your_key

# TELEGRAM BOT
TELEGRAM_BOT_TOKEN=123456789:ABC...
TELEGRAM_ADMIN_CHAT_ID=123456789
TELEGRAM_WEBHOOK_SECRET=bilimmakon_secret_2024

# APP URL
NEXT_PUBLIC_APP_URL=https://bilimmakon.vercel.app

# ADMIN TELEGRAM USERNAME (@ belgisisiz)
# Foydalanuvchi ro'yxatdan o'tgach shu username ga murojaat qiladi
NEXT_PUBLIC_ADMIN_TELEGRAM=your_telegram_username

# QOSHIMCHA ADMIN HIMOYA (ixtiyoriy lekin tavsiya etiladi)
# Admin login sahifasida bu kalit ham so'raladi
# Bo'sh qoldirilsa, faqat email+parol bilan kirish mumkin
ADMIN_SECRET_KEY=YourStr0ngAdminSecret!2024
